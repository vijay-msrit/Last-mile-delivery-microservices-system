            "description": "Create a new order (publishes order-created event to Kafka)"
          }
        },
        {
          "name": "Assign Driver to Order",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/orders/api/orders/1/assign?driverId=1",
              "host": ["{{gateway_url}}"],
              "path": ["orders", "api", "orders", "1", "assign"],
              "query": [
                {
                  "key": "driverId",
                  "value": "1"
                }
              ]
            },
            "description": "Manually assign a driver to an order"
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/orders/api/orders/1/status?status=PICKED_UP",
              "host": ["{{gateway_url}}"],
              "path": ["orders", "api", "orders", "1", "status"],
              "query": [
                {
                  "key": "status",
                  "value": "PICKED_UP",
                  "description": "Options: PENDING, ASSIGNED, PICKED_UP, DELIVERED, CANCELLED"
                }
              ]
            },
            "description": "Update order status"
          }
        },
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/orders/api/orders",
              "host": ["{{gateway_url}}"],
              "path": ["orders", "api", "orders"]
            },
            "description": "Get list of all orders"
