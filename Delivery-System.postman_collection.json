              "query": [
                {
                  "key": "lat",
                  "value": "19.0900"
                },
                {
                  "key": "lng",
                  "value": "72.8900"
                }
              ]
            },
            "description": "Send GPS location to Kafka (tracking-service will consume it)"
          }
        },
        {
          "name": "Get Available Drivers",
          "request": {
            "method": "GET",
