              "raw": "{{gateway_url}}/driver-service/api/drivers/1/status",
              "host": ["{{gateway_url}}"],
              "path": ["driver-service", "api", "drivers", "1", "status"]
            },
            "description": "Toggle driver availability status"
          }
        },
        {
          "name": "Update Driver Location",
          "request": {
            "method": "PATCH",
