    {
      "name": "3. Order Service",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"John Doe\",\n  \"pickupAddress\": \"123 Main St, Mumbai\",\n  \"deliveryAddress\": \"456 Park Ave, Mumbai\",\n  \"pickupLat\": 19.0760,\n  \"pickupLng\": 72.8777,\n  \"deliveryLat\": 19.1234,\n  \"deliveryLng\": 72.9012\n}"
