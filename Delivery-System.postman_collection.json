                {
                  "key": "lng",
                  "value": "72.8850"
                }
              ]
            },
            "description": "Update driver's current location"
          }
        },
        {
          "name": "Send GPS Event to Kafka",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/driver-service/api/drivers/1/gps?lat=19.0900&lng=72.8900",
