              "path": ["driver-service", "api", "drivers", "1", "orders", "1", "pickup"]
            },
            "description": "Driver marks order as picked up (publishes Kafka event)"
          }
        },
        {
          "name": "Mark Order Delivered",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/driver-service/api/drivers/1/orders/1/delivered",
