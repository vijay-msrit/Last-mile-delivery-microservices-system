## 4. API Integration Architecture

### 4.1 Axios Client with JWT Interceptor

```javascript
// src/api/axiosClient.js вЂ” Conceptual
const api = axios.create({ baseURL: 'http://localhost:8080' });

api.interceptors.request.use((config) => {
  const token = useAuthStore.getState().token;
  if (token) config.headers.Authorization = `Bearer ${token}`;
  return config;
});

api.interceptors.response.use(
  (res) => res,
  (err) => {
    if (err.response?.status === 401) {
      useAuthStore.getState().logout();
      window.location.href = '/login';
    }
    return Promise.reject(err);
  }
);
```

### 4.2 API Module Mapping

```javascript
// authApi.js
POST /api/auth/register  в†’ { email, password, role }   в†’ "Registered"
POST /api/auth/login     в†’ ?email=...&password=...     в†’ JWT string

// orderApi.js
POST   /api/orders           в†’ { userId, pickupAddress, deliveryAddress }  в†’ Order
GET    /api/orders           в†’ вЂ”                                          в†’ Order[]
PATCH  /api/orders/{id}/assign  в†’ ?driverId=...                           в†’ Order
PATCH  /api/orders/{id}/status  в†’ ?status=...                             в†’ Order

// driverApi.js
POST   /api/drivers/register              в†’ { name, vehicleNumber }  в†’ DriverResponse
PATCH  /api/drivers/{id}/status           в†’ вЂ”                        в†’ DriverResponse
PATCH  /api/drivers/{id}/location         в†’ ?lat=...&lng=...         в†’ DriverResponse
POST   /api/drivers/{id}/gps             в†’ ?lat=...&lng=...         в†’ "GPS sent"
GET    /api/drivers/available            в†’ вЂ”                        в†’ DriverResponse[]
POST   /api/drivers/{dId}/orders/{oId}/pickup     в†’ вЂ”               в†’ "Picked up"
POST   /api/drivers/{dId}/orders/{oId}/delivered   в†’ вЂ”              в†’ "Delivered"

// trackingApi.js
GET    /tracking/{driverId}              в†’ вЂ”                        в†’ "lat,lng" string
```

